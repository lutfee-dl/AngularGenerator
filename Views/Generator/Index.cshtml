@using AngularGenerator.Core.Models
@model ComponentDefinition

@{
    ViewData["Title"] = "Angular CRUD Generator";
    Layout = null;

    // ��ʶҹ� Select All �ͧ CRUD
    bool isAllCrud = Model?.IsGet == true && Model?.IsGetById == true && Model?.IsPost == true && Model?.IsUpdate == true && Model?.IsDelete == true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Angular CRUD Generator</title>
    
    <!-- Favicon -->
    <link rel="icon" type="image/x-icon" href="~/favicon.ico" asp-append-version="true">

    <!-- Add-on Libraries -->
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" asp-append-version="true">
    <link rel="stylesheet" href="~/lib/font-awesome/css/all.min.css" asp-append-version="true">
    <script src="~/lib/jszip/jszip.min.js" asp-append-version="true"></script>
    <script src="~/lib/filesaver/FileSaver.min.js" asp-append-version="true"></script>
    <!-- prism.js -->
    <link href="~/lib/prism/css/prism.min.css" rel="stylesheet" asp-append-version="true" />
    <link href="~/lib/prism/css/prism-toolbar.min.css" rel="stylesheet" asp-append-version="true" />
    <script src="~/lib/prism/js/prism.min.js" asp-append-version="true"></script>
    <script src="~/lib/prism/js/prism-typescript.min.js" asp-append-version="true"></script>
    <script src="~/lib/prism/js/prism-css.min.js" asp-append-version="true"></script>
    <script src="~/lib/prism/js/prism-toolbar.min.js" asp-append-version="true"></script>

    <!-- Custom CSS -->
    <link rel="stylesheet" href="~/css/generator.css" asp-append-version="true">
    
    <!-- Fomantic UI (Modern Fork of Semantic UI) -->
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/fomantic-ui@2.9.3/dist/semantic.min.css">
</head>
<body>

    <nav class="main-header shadow-sm d-flex justify-content-between align-items-center px-4 py-2 bg-primary" 
        style="border-bottom: 2px solid #000000;">
        
        <div class="d-flex align-items-center gap-2">
            <div class="brand-icon-wrapper me-3">
                <i class="fa-brands fa-angular text-white fs-4"></i>
            </div>
            <h4 class="m-0 fw-bold text-white tracking-tight" style="letter-spacing: -0.5px;">
                Angular <span class="text-white fw-light">CRUD Generator</span>
            </h4>
            <!-- Version badge -->
            <span style="
                background: rgba(255,255,255,0.15);
                border: 1px solid rgba(255,255,255,0.35);
                color: #fff;
                font-size: 1rem;
                font-weight: 700;
                padding: 2px 8px;
                border-radius: 99px;
                letter-spacing: 0.5px;
                white-space: nowrap;
                backdrop-filter: blur(4px);
            ">
               Supports | Angular v17+
            </span>
        </div>

        <div class="d-flex align-items-center gap-3">
            <div id="dbStatusBadge" 
                onclick="openDbConfigModal()"
                class="db-status-pill d-flex align-items-center px-3 py-2" 
                style="background: rgb(255, 255, 255); border-radius: 50px; cursor: pointer; transition: all 0.3s ease; border: 1px solid rgba(255,255,255,0.1);">
                
                <span class="status-dot-pulse me-2" id="dbStatusDot"></span>
                <span id="dbStatusText" class="small fw-medium text-black uppercase">Checking...</span>
                <i class="fa-solid fa-gear ms-3 text-black" style="font-size: 0.8rem;"></i>
            </div>

            <button class="btn btn-outline-light btn-sm rounded-circle border-0" 
                    onclick="checkDbStatus()" 
                    style="width: 32px; height: 32px; background: rgba(255,255,255,0.05);">
                <i class="fa-solid fa-rotate-right" style="font-size: 0.8rem;"></i>
            </button>
        </div>
    </nav>

    <div class="container-fluid mt-4 px-4">
        <form action="/Generator/Index" method="post" id="genForm" novalidate>
            <div class="row">

                <div class="col-md-4">
                    <div class="card card-settings mb-4 shadow-sm">
                        <div class="card-header bg-primary">Configure</div>
                        <div class="card-body bg-light">

                            <!-- Data Source Selection -->
                            <div class="mb-3">
                                <label class="form-label fw-bold text-primary">
                                    <i class="fas fa-database"></i> Data Source
                                </label>
                                <div class="btn-group d-flex" role="group">
                                    <input type="radio" class="btn-check" name="dataSource" id="sqlSource" value="sql" checked onchange="toggleDataSource()">
                                    <label class="btn btn-outline-primary btn-sm" for="sqlSource" 
                                           data-bs-toggle="tooltip" title="Supports SQL Server/MySQL/PostgreSQL">
                                        <i class="fas fa-database"></i> SQL Server
                                    </label>

                                    <input type="radio" class="btn-check" name="dataSource" id="apiSource" value="api" onchange="toggleDataSource()">
                                    <label class="btn btn-outline-primary btn-sm" for="apiSource"
                                           data-bs-toggle="tooltip" title="Supports JSON Schema from REST API Endpoint">
                                        <i class="fas fa-cloud"></i> REST API
                                    </label>

                                    <input type="radio" class="btn-check" name="dataSource" id="jsonSource" value="json" onchange="toggleDataSource()">
                                    <label class="btn btn-outline-primary btn-sm" for="jsonSource"
                                           data-bs-toggle="tooltip" title="Supports JSON Schema from JSON file">
                                        <i class="fas fa-code"></i> JSON
                                    </label>
                                </div>
                            </div>

                            <!-- SQL Server / AS400 Section -->
                            <div id="sqlSection" class="data-source-section">
                                <!-- Standard Table Input (Hidden if AS400) -->
                                <div id="standardTableSection" class="mb-3">
                                    <label class="form-label fw-bold text-primary">Select Table</label>
                                    
                                    <div class="joined-group mb-2">
                                        <!-- Native input + datalist: search/autocomplete with zero JS library dependency -->
                                        <input type="text" 
                                               name="tableName" 
                                               id="tableNameInput"
                                               class="form-control"
                                               list="tableDataList"
                                               placeholder="Search &amp; Select Table..."
                                               autocomplete="off">
                                        <datalist id="tableDataList">
                                            <!-- options injected by loadTableList() -->
                                        </datalist>
                                        <button class="btn-refresh" type="button" onclick="loadTableList()" title="Refresh table list">
                                            <i class="fa-solid fa-rotate-right"></i>
                                        </button>
                                    </div>
                                    
                                    <button class="btn btn-primary w-100" type="button" id="btnLoad" onclick="loadColumns()"
                                            data-bs-toggle="tooltip" title="Load columns for the specified table">
                                        <i class="fa-solid fa-sync"></i> Load Columns Data
                                    </button>

                                    <small class="text-muted" id="loadStatus"></small>
                                </div>

                                <!-- AS400 Special Fields (Shown only if AS400) -->
                                <div id="as400SpecialSection" class="mb-3" style="display: none;">
                                    <div class="row g-2">
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold text-primary">Library (Schema)</label>
                                            <input type="text" id="libraryInput" class="form-control form-control-sm" 
                                                   placeholder="e.g. QGPL" onkeyup="syncAs400TableName()">
                                        </div>
                                        <div class="col-md-6">
                                            <label class="form-label fw-bold text-primary">Table Name</label>
                                            <input type="text" id="tableNameAs400Input" class="form-control form-control-sm" 
                                                   placeholder="e.g. CUSMAS" onkeyup="syncAs400TableName()">
                                        </div>
                                    </div>
                                    <small class="text-muted mt-1 d-block">
                                        <i class="fas fa-info-circle"></i> AS400 requires both Library and Table Name for field discovery.
                                    </small>

                                    <button class="btn btn-primary w-100 mt-2" type="button" id="btnLoadAs400" onclick="loadColumns()"
                                            data-bs-toggle="tooltip" title="Load columns from AS400 table">
                                        <i class="fa-solid fa-sync"></i> Load Columns Data
                                    </button>

                                    <small class="text-muted" id="loadStatusAs400"></small>
                                </div>
                                    
                            </div>

                            <!-- REST API Section -->
                            <div id="apiSection" class="data-source-section" style="display: none;">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-link"></i> API URL
                                    </label>
                                    <input type="url" class="form-control" id="apiUrl" placeholder="https://api.example.com/products">
                                </div>
                                
                                <div class="row mb-3">
                                    <div class="col-6">
                                        <label class="form-label">Method</label>
                                        <select class="form-select form-select-sm" id="httpMethod">
                                            <option value="GET" selected>GET</option>
                                        </select>
                                    </div>
                                    <div class="col-6">
                                        <label class="form-label">Entity Name</label>
                                        <input type="text" class="form-control form-control-sm" id="entityNameApi" placeholder="Product" value="Item">
                                    </div>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">
                                        Headers (Optional)
                                        <button type="button" class="btn btn-sm btn-outline-secondary" onclick="addApiHeader()">
                                            <i class="fas fa-plus"></i>
                                        </button>
                                    </label>
                                    <div id="apiHeadersContainer" class="small"></div>
                                </div>

                                <button type="button" class="btn btn-primary btn-sm w-100" onclick="fetchApiSchema()">
                                    <i class="fas fa-cloud-download-alt"></i> Fetch Schema
                                </button>
                            </div>

                            <!-- JSON Sample Section -->
                            <div id="jsonSection" class="data-source-section" style="display: none;">
                                <div class="mb-3">
                                    <label class="form-label fw-bold">
                                        <i class="fas fa-code"></i> Paste JSON Sample
                                    </label>
                                    <textarea class="form-control font-monospace small" id="jsonSample" rows="8" 
                                              placeholder='&#123;
                                                        "id": 1,
                                                        "name": "Product A",
                                                        "price": 99.99,
                                                        "inStock": true
                                                        &#125;'></textarea>
                                    <small class="form-text text-muted">Single object or array</small>
                                </div>

                                <div class="mb-3">
                                    <label class="form-label">Entity Name</label>
                                    <input type="text" class="form-control form-control-sm" id="entityNameJson" placeholder="Product" value="Item">
                                </div>

                                <button type="button" class="btn btn-success btn-sm w-100" onclick="parseJsonSchema()">
                                    <i class="fas fa-magic"></i> Parse JSON
                                </button>
                            </div>

                            <!-- Hidden field to store parsed fields data -->
                            <input type="hidden" id="parsedFieldsData" name="parsedFieldsData" value="">

                            <div class="card mb-3">
                                <div class="card-body py-2 pt-2">
                                    <label class="fw-bold mb-2 d-block">
                                        FieldName
                                        <i class="fas fa-info-circle text-muted ms-1" title="Primary Key for GetById, Update, Delete"></i> 
                                    </label>

                                    <div class="form-check border-bottom pb-2 mb-2">
                                        <input class="form-check-input" type="checkbox" id="selectAllFields" checked onchange="toggleAllFields(this)">
                                        <label class="form-check-label fw-bold text-primary" for="selectAllFields">Select all</label>
                                    </div>

                                    <!-- SQL Server Field Container -->
                                    <div id="sqlFieldContainer" class="field-container border rounded p-2 bg-white" style="max-height: 280px; overflow-y: auto;">
                                        @if (Model?.Fields != null && Model.Fields.Count > 0)
                                        {
                                            // Support List of selected fields (if null then load all)
                                            var selected = ViewBag.SelectedFields as List<string>;

                                            <table class="table table-sm mb-0">
                                                <thead>
                                                    <tr>
                                                        <th style="width: 40px;">
                                                            <i class="fas fa-check text-success" title="Include"></i>
                                                        </th>
                                                        <th>Field Name</th>
                                                        <th>Type</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var f in Model.Fields)
                                                    {
                                                        var isChecked = (selected == null || selected.Count == 0 || selected.Contains(f.FieldName)) ? "checked" : "";
                                                        // PK fields are always checked and disabled (cannot uncheck)
                                                        var isDisabled = f.IsPrimaryKey ? "disabled" : "";
                                                        var pkChecked = f.IsPrimaryKey ? "checked" : isChecked;

                                                        <tr class="@(f.IsPrimaryKey ? "table-warning" : "")">
                                                            <td class="text-center">
                                                                <input class="form-check-input field-checkbox" type="checkbox" 
                                                                       name="selectedFields" value="@f.FieldName" 
                                                                       @pkChecked @isDisabled>
                                                                @* Hidden input for PK fields to ensure they are submitted even if disabled *@
                                                                @if (f.IsPrimaryKey)
                                                                {
                                                                    <input type="hidden" name="selectedFields" value="@f.FieldName">
                                                                }
                                                            </td>
                                                            <td>
                                                                <span class="fw-bold text-dark small">@f.FieldName</span>
                                                                @if (f.IsPrimaryKey)
                                                                {
                                                                    <i class="fas fa-key text-warning ms-1" title="Primary Key (Required)"></i>
                                                                    <span class="badge bg-warning text-dark ms-1" style="font-size: 0.65rem;">PK</span>
                                                                }
                                                            </td>
                                                            <td>
                                                                <span class="text-muted small">@f.TsType</span>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                        else
                                        {
                                            <div class="h-100 d-flex align-items-center justify-content-center" style="min-height: 120px;">
                                                <small class="text-muted fst-italic" style="color:red">Table not found.</small>
                                            </div>
                                        }
                                    </div>

                                    <!-- API Field Container -->
                                    <div id="apiFieldContainer" class="field-container border rounded p-2 bg-white" style="max-height: 280px; overflow-y: auto; display: none;">
                                        <div class="h-100 d-flex align-items-center justify-content-center" style="min-height: 120px;">
                                            <small class="text-muted fst-italic">Please fetch schema to load fields from API</small>
                                        </div>
                                    </div>

                                    <!-- JSON Field Container -->
                                    <div id="jsonFieldContainer" class="field-container border rounded p-2 bg-white" style="max-height: 280px; overflow-y: auto; display: none;">
                                        <div class="h-100 d-flex align-items-center justify-content-center" style="min-height: 120px;">
                                            <small class="text-muted fst-italic">Please parse JSON to load fields</small>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Component Name</label>
                                <input type="text" name="componentName" class="form-control"
                                       placeholder="Auto-generated if empty (e.g. Products)"
                                       value="@(Model?.EntityName != null && Model.EntityName != ViewBag.LastTableName ? Model?.EntityName : "")">
                            </div>

                            <!-- Report/CRUD Mode Selection -->
                            <div class="card mb-3">
                                @{
                                    var selectedMode = ViewBag.GenerationMode ?? "Report";
                                }
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="generationMode" id="modeReport" value="Report" @(selectedMode == "Report" ? "checked" : "") onchange="toggleCrudOptions()">
                                    <label class="btn btn-outline-primary btn-lg" for="modeReport"
                                           data-bs-toggle="tooltip" title="Read-only mode (no Create/Update/Delete)">
                                        <i class="fas fa-file-alt"></i> Report
                                    </label>
                                    
                                    <input type="radio" class="btn-check" name="generationMode" id="modeCrud" value="CRUD" @(selectedMode == "CRUD" ? "checked" : "") onchange="toggleCrudOptions()">
                                    <label class="btn btn-outline-primary btn-lg" for="modeCrud"
                                           data-bs-toggle="tooltip" title="Full CRUD operations mode (Create/Read/Update/Delete)">
                                        <i class="fas fa-database"></i> CRUD
                                    </label>
                                </div>
                                @* <small class="text-muted d-block mt-2">
                                    <strong>Report:</strong> Read-only mode (no Create/Update/Delete)
                                    <br> 
                                    <strong>CRUD:</strong> Full CRUD operations mode (Create/Read/Update/Delete)
                                </small>  *@
                            </div>

                            <div class="card mb-3" id="crudOptionsCard">
                                <div class="card-body py-2">
                                    <label class="fw-bold mb-2 d-block">Choose CRUD</label>

                                    <div class="form-check border-bottom pb-2 mb-2">
                                        <input class="form-check-input" type="checkbox" id="selectAllCrud"
                                               onchange="toggleAllCrud(this)" @(isAllCrud ? "checked" : "")>
                                        <label class="form-check-label fw-bold text-primary " for="selectAllCrud">Select All</label>
                                    </div>

                                    <div class="row g-2">
                                        <div class="col-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="IsGet" asp-for="IsGet" checked disabled>
                                                <input type="hidden" name="IsGet" value="true">
                                                <label class="form-check-label text-muted" for="IsGet">
                                                    <i class="fas fa-lock me-1"></i> Get (Read)
                                                    <span class="badge bg-primary ms-2" style="font-size: 0.7rem;">REQUIRED</span>
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input crud-checkbox" type="checkbox" id="IsGetById" asp-for="IsGetById" onchange="updateGetByIdRequirement()">
                                                <label class="form-check-label" for="IsGetById">Get By ID</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input crud-checkbox" type="checkbox" id="IsPost" asp-for="IsPost" onchange="updateGetByIdRequirement()">
                                                <label class="form-check-label" for="IsPost">Post (Create)</label>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="form-check">
                                                <input class="form-check-input crud-checkbox" type="checkbox" id="IsUpdate" asp-for="IsUpdate" onchange="updateGetByIdRequirement()">
                                                <label class="form-check-label" for="IsUpdate">Update</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input crud-checkbox" type="checkbox" id="IsDelete" asp-for="IsDelete" onchange="updateGetByIdRequirement()">
                                                <label class="form-check-label" for="IsDelete">Delete</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- API Base URL  -->
                            <div class="mb-3" id="apiBaseUrlSection">
                                <label class="form-label fw-bold">
                                    API Base URL
                                    <i class="fas fa-info-circle text-muted ms-1" title="API Base URL for making HTTP requests"></i>
                                </label>
                                <input type="text" id="apiBaseUrl" name="apiBaseUrl" class="form-control"
                                       placeholder="e.g. http://localhost:3000/api/exemples"
                                       value="@ViewBag.ApiBaseUrl">
                            </div>

                            <!-- NEW: UI Layout Selection -->
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white py-2">
                                    <i class="fas fa-layout"></i> UI Layout
                                </div>
                                <div class="card-body py-2">
                                    @{
                                        var selectedLayout = ViewBag.LayoutType ?? Model?.LayoutType.ToString() ?? "TableView";
                                    }
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" name="layoutType" id="layoutTable" 
                                               value="TableView" @(selectedLayout == "TableView" ? "checked" : "")>
                                        <label class="form-check-label" for="layoutTable">
                                            <i class="fas fa-table"></i> Table View
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="layoutType" id="layoutCard" 
                                               value="CardView" @(selectedLayout == "CardView" ? "checked" : "")>
                                        <label class="form-check-label" for="layoutCard">
                                            <i class="fas fa-th-large"></i> Card View
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- CSS Framework Selection -->
                            <div class="card mb-3">
                                <div class="card-header bg-success text-white py-2">
                                    <i class="fas fa-palette"></i> CSS Framework
                                </div>
                                <div class="card-body py-2">
                                    @{
                                        var selectedFramework = ViewBag.CssFramework ?? Model?.CssFramework.ToString() ?? "Bootstrap";
                                    }
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" name="cssFramework" id="cssBasic" 
                                               value="BasicCSS" @(selectedFramework == "BasicCSS" ? "checked" : "")>
                                        <label class="form-check-label" for="cssBasic"
                                               data-bs-toggle="tooltip" title="Basic CSS with minimal styling">
                                            <i class="fas fa-file-code"></i> Basic CSS
                                            <small class="text-muted d-block">Minimal .css files</small>
                                        </label>
                                    </div>
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" name="cssFramework" id="cssBootstrap" 
                                               value="Bootstrap" @(selectedFramework == "Bootstrap" ? "checked" : "")>
                                        <label class="form-check-label" for="cssBootstrap"
                                               data-bs-toggle="tooltip" title="Bootstrap 5 classes (requires installing Bootstrap)">
                                            <i class="fab fa-bootstrap"></i> Bootstrap 5
                                            <small class="text-muted d-block">Bootstrap classes</small>
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="cssFramework" id="cssMaterial" 
                                               value="AngularMaterial" @(selectedFramework == "AngularMaterial" ? "checked" : "")>
                                        <label class="form-check-label" for="cssMaterial"
                                               data-bs-toggle="tooltip" title="Angular Material components (requires installing @@angular/material)">
                                            <i class="fas fa-brush"></i> Angular Material
                                            <small class="text-muted d-block">Material Design</small>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- Separate Interface File Option -->
                            <div class="card mb-3">
                                <div class="card-header bg-warning text-dark py-2">
                                    <i class="fas fa-file-code"></i> File Options
                                </div>
                                <div class="card-body py-2">
                                    <div class="form-check">
                                        <input class="form-check-input" type="checkbox" id="separateInterface" name="separateInterface" value="true" @((ViewBag.SeparateInterface == true) ? "checked" : "")>
                                        <label class="form-check-label" for="separateInterface">
                                            <i class="fas fa-file-export"></i> Separate Interface File (.interface.ts)
                                            <small class="text-muted d-block">Generate a separate <code>.interface.ts</code> file for importing into components and services</small>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <button type="button" class="btn btn-generate w-100 shadow-sm py-2" onclick="handleGenerateClick()">
                                <i class="fas fa-cog"></i> Generate Code
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Result Section (col-md-8) -->
                <div class="col-md-8 h-100">
                    @if (Model != null && !string.IsNullOrEmpty(Model.GeneratedHtml))
                    {
                        <label class="fw-bold mb-1">Create Component</label>
                        <div class="bg-secondary text-white p-2 rounded mb-3 d-flex justify-content-between align-items-center font-monospace">
                            <span id="cliCommand">ng generate component <strong>@(Model?.Selector ?? "<component-name>")</strong> --standalone</span>
                            <button type="button" class="btn btn-sm btn-dark" onclick="copyText('cliCommand', true)"><i class="fa-regular fa-copy"></i></button>
                        </div>        

                        <!-- Setup Guide Action -->
                        <div class="alert alert-primary border-0 shadow-sm d-flex justify-content-between align-items-center py-2 mb-3">
                            <div class="d-flex align-items-center">
                                <div class="bg-primary text-white rounded-circle p-2 me-3" style="width: 35px; height: 35px; display: flex; align-items: center; justify-content: center;">
                                    <i class="fas fa-magic"></i>
                                </div>
                                <div>
                                    <h6 class="mb-0 fw-bold">Ready to implement?</h6>
                                    <small class="text-muted">Follow our step-by-step guide to integrate this code.</small>
                                </div>
                            </div>
                            <button type="button" class="btn btn-primary btn-sm px-3 shadow-sm fw-bold" data-bs-toggle="modal" data-bs-target="#guideModal">
                                <i class="fas fa-book-open me-1"></i> Open Setup Guide
                            </button>
                        </div>

                        <div class="card card-result shadow-sm h-75" style="margin-bottom: 10px;" id="resultCard">
                            <div class="card-header">
                                <span>Result for @Model?.EntityName</span>
                                <div class="d-inline-block ms-3">
                                    <span class="badge bg-info">
                                        <i class="fas fa-@(Model?.LayoutType == UILayoutType.TableView ? "table" : "th-large")"></i>
                                        @Model?.LayoutType
                                    </span>
                                    <span class="badge bg-@(Model?.CssFramework == CSSFramework.BasicCSS ? "warning" : Model?.CssFramework == CSSFramework.Bootstrap ? "primary" : "success")">
                                        @Model?.CssFramework
                                        @if (Model?.CssFramework == CSSFramework.BasicCSS)
                                        {
                                            <i class="fas fa-file-code ms-1"></i>
                                        }
                                    </span>
                                </div>
                                <button type="button" class="btn btn-warning btn-sm float-end fw-bold px-3 shadow-sm text-dark" onclick="downloadAllAsZip()">
                                    <i class="fas fa-download me-1"></i> Download All (ZIP)
                                </button>
                            </div>
                            <div class="card-body p-0 result-area">
                                <ul class="nav nav-tabs bg-light px-2 pt-2" role="tablist">
                                    <li class="nav-item"><a class="nav-link active" data-bs-toggle="tab" href="#tab-html">HTML</a></li>
                                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-ts">TypeScript</a></li>
                                    <li class="nav-item"><a class="nav-link" data-bs-toggle="tab" href="#tab-svc">Service</a></li>
                                    <li class="nav-item" id="tab-interface-nav" style="@(!string.IsNullOrEmpty(Model?.GeneratedInterface) ? "" : "display:none")">
                                        <a class="nav-link" data-bs-toggle="tab" href="#tab-interface">Interface</a>
                                    </li>
                                    <li class="nav-item" id="tab-css-nav" style="@(!string.IsNullOrEmpty(Model?.GeneratedCss) ? "" : "display:none")">
                                        <a class="nav-link" data-bs-toggle="tab" href="#tab-css">CSS</a>
                                    </li>
                                </ul>
                                <div class="tab-content h-75">
                                    <div class="tab-pane fade show active h-100" id="tab-html">
                                        <button type="button" class="btn btn-secondary btn-sm copy-btn" onclick="copyText('codeHtml')"><i class="fa-regular fa-copy"></i> Copy HTML</button>
                                        <pre class="h-100 m-0" style="overflow: auto;"><code id="codeHtml" class="language-markup">@Model?.GeneratedHtml</code></pre>
                                    </div>
                                    <div class="tab-pane fade h-100" id="tab-ts">
                                        <button type="button" class="btn btn-secondary btn-sm copy-btn" onclick="copyText('codeTs')"><i class="fa-regular fa-copy"></i> Copy TS</button>
                                        <pre class="h-100 m-0" style="overflow: auto;"><code id="codeTs" class="language-typescript">@Model?.GeneratedTs</code></pre>
                                    </div>
                                    <div class="tab-pane fade h-100" id="tab-svc">
                                        <button type="button" class="btn btn-secondary btn-sm copy-btn" onclick="copyText('codeSvc')"><i class="fa-regular fa-copy"></i> Copy Service</button>
                                        <pre class="h-100 m-0" style="overflow: auto;"><code id="codeSvc" class="language-typescript">@Model?.GeneratedService</code></pre>
                                    </div>
                                    <div class="tab-pane fade h-100" id="tab-interface">
                                        <button type="button" class="btn btn-secondary btn-sm copy-btn" onclick="copyText('codeInterface')"><i class="fa-regular fa-copy"></i> Copy Interface</button>
                                        <pre class="h-100 m-0" style="overflow: auto;"><code id="codeInterface" class="language-typescript">@Model?.GeneratedInterface</code></pre>
                                    </div>
                                    <div class="tab-pane fade h-100" id="tab-css">
                                        <button type="button" class="btn btn-secondary btn-sm copy-btn" onclick="copyText('codeCss')"><i class="fa-regular fa-copy"></i> Copy CSS</button>
                                        <pre class="h-100 m-0" style="overflow: auto;"><code id="codeCss" class="language-css">@Model?.GeneratedCss</code></pre>
                                    </div>
                                </div>
                            </div>
                        </div>
                    }
                    else
                    {
                        <!-- Result placeholder -->
                        <div class="card card-result shadow-sm" style="margin-bottom: 10px; min-height: 600px;" id="resultPlaceholder">
                            <div class="card-header">
                                <span>Result</span>
                                <div class="d-inline-block ms-3">
                                </div>
                            </div>
                            <div class="card-body p-0 result-area d-flex align-items-center justify-content-center" style="min-height: 550px;">
                               <!-- Loading state -->
                                <div class="text-center" id="loadingState" style="display: none;">
                                    <div class="spinner-border text-primary" role="status" style="width: 3rem; height: 3rem;">
                                        <span class="visually-hidden">Loading...</span>
                                    </div>
                                    <h5 class="mt-3 text-primary">
                                        <i class="fas fa-cog fa-spin me-2"></i>Generating code...
                                    </h5>
                                    <p class="small text-muted">Please wait while the code is being generated...</p>
                                    <div class="progress mt-3" style="width: 300px; height: 4px;">
                                        <div class="progress-bar progress-bar-striped progress-bar-animated" role="progressbar" style="width: 100%"></div>
                                    </div>
                                </div>
                                <!-- Empty state -->
                                <div class="text-center text-muted" id="emptyState">
                                    <i class="fas fa-code fa-4x mb-3" style="opacity: 0.3;"></i>
                                    <h5 class="fst-italic">Generated code will appear here...</h5>
                                    <p class="small">Fill in the information on the left and press the Generate Code.</p>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </form>

        <!-- Database Configuration Modal -->
        <div class="modal fade" id="dbConfigModal" tabindex="-1">
            <div class="modal-dialog modal-lg">
                <div class="modal-content">
                    <div class="modal-header bg-primary text-white">
                        <h5 class="modal-title">
                            <i class="fas fa-database me-2"></i>Database Configuration
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body">
                        <!-- Saved Configurations Section -->
                        <div class="card mb-3 bg-light">
                            <div class="card-header d-flex justify-content-between align-items-center">
                                <span><i class="fas fa-history me-2"></i>Saved Configurations</span>
                                <button class="btn btn-sm btn-outline-secondary" onclick="loadSavedConfigurations()" title="Refresh">
                                    <i class="fas fa-sync"></i>
                                </button>
                            </div>
                            <div class="card-body" style="max-height: 200px; overflow-y: auto;">
                                <div id="savedConfigsList">
                                    <small class="text-muted fst-italic">No saved configurations. Create one below.</small>
                                </div>
                            </div>
                        </div>

                        <!-- Database Type Selection -->
                        <div class="mb-4">
                            <label class="form-label fw-bold">
                                <i class="fas fa-server"></i> Database Type
                            </label>
                            <div class="btn-group w-100" role="group">
                                <input type="radio" class="btn-check" name="modalDbType" id="modalSqlServer" value="SqlServer" checked onchange="updateDbFields()">
                                <label class="btn btn-outline-primary" for="modalSqlServer">
                                    <i class="fas fa-database"></i> SQL Server
                                </label>

                                <input type="radio" class="btn-check" name="modalDbType" id="modalMySQL" value="MySQL" onchange="updateDbFields()">
                                <label class="btn btn-outline-primary" for="modalMySQL">
                                    <i class="fas fa-dolphin"></i> MySQL
                                </label>

                                <input type="radio" class="btn-check" name="modalDbType" id="modalPostgreSQL" value="PostgreSQL" onchange="updateDbFields()">
                                <label class="btn btn-outline-primary" for="modalPostgreSQL">
                                    <i class="fas fa-elephant"></i> PostgreSQL
                                </label>

                                <input type="radio" class="btn-check" name="modalDbType" id="modalAS400" value="AS400" onchange="updateDbFields()">
                                <label class="btn btn-outline-primary" for="modalAS400">
                                    <i class="fas fa-server"></i> AS400
                                </label>
                            </div>
                        </div>

                        <!-- Connection String Input -->
                        <div class="mb-3">
                            <label class="form-label fw-bold">
                                <i class="fas fa-link"></i> Connection String
                            </label>
                            <textarea class="form-control font-monospace small" id="modalConnString" rows="3" 
                                      placeholder="Server=localhost;Database=mydb;..."></textarea>
                            <small class="form-text text-muted d-block mt-1" id="connStringHint"></small>
                        </div>

                        <!-- Quick Config (Alternative) -->
                        <div class="card mb-3">
                            <div class="card-header bg-light">
                                <small class="text-muted">Or fill in details instead</small>
                            </div>
                            <div class="card-body">
                                <div class="row g-2">
                                    <div class="col-md-6">
                                        <label class="form-label small">Server/Host</label>
                                        <input type="text" class="form-control form-control-sm" id="modalServer" placeholder="localhost">
                                    </div>
                                    <div class="col-md-6" id="modalDatabaseField">
                                        <label class="form-label small" id="modalDatabaseLabel">Database</label>
                                        <input type="text" class="form-control form-control-sm" id="modalDatabase" placeholder="mydatabase">
                                    </div>
                                    <div class="col-md-4" id="modalPortField">
                                        <label class="form-label small">Port</label>
                                        <input type="number" class="form-control form-control-sm" id="modalPort" placeholder="3306">
                                    </div>
                                    <div class="col-md-4" id="modalUsernameField">
                                        <label class="form-label small">Username</label>
                                        <input type="text" class="form-control form-control-sm" id="modalUsername" placeholder="root">
                                    </div>
                                    <div class="col-md-4" id="modalPasswordField">
                                        <label class="form-label small">Password</label>
                                        <input type="password" class="form-control form-control-sm" id="modalPassword">
                                    </div>
                                </div>
                                <div class="form-check mt-2" id="modalWindowsAuthField">
                                    <input class="form-check-input" type="checkbox" id="modalWindowsAuth" checked onchange="toggleAuthFields()">
                                    <label class="form-check-label small" for="modalWindowsAuth">
                                        Use Windows Authentication
                                    </label>
                                </div>
                                <button class="btn btn-sm btn-secondary mt-2" onclick="buildConnectionString()">
                                    <i class="fas fa-magic"></i> Build Connection String
                                </button>
                            </div>
                        </div>

                        <!-- Save Configuration Section -->
                        <div class="card mb-3 border-success">
                            <div class="card-header bg-success text-white">
                                <i class="fas fa-save me-2"></i>Save This Configuration
                            </div>
                            <div class="card-body">
                                <div class="mb-2">
                                    <label class="form-label small">Configuration Name</label>
                                    <input type="text" class="form-control form-control-sm" id="saveConfigName" placeholder="e.g., Production DB, Development DB">
                                </div>
                                <div class="mb-2">
                                    <label class="form-label small">Description (Optional)</label>
                                    <input type="text" class="form-control form-control-sm" id="saveConfigDescription" placeholder="e.g., Main production database">
                                </div>
                                <div class="form-check mb-2">
                                    <input class="form-check-input" type="checkbox" id="saveConfigDefault">
                                    <label class="form-check-label small" for="saveConfigDefault">
                                        Set as default
                                    </label>
                                </div>
                                <button class="btn btn-sm btn-success w-100" onclick="saveCurrentConfiguration()">
                                    <i class="fas fa-save"></i> Save Configuration
                                </button>
                            </div>
                        </div>

                        <!-- Test Connection -->
                        <div class="d-flex align-items-center gap-2 mb-3">
                            <button class="btn btn-info" onclick="testConnection()">
                                <i class="fas fa-plug"></i> Test Connection
                            </button>
                            <span id="testResult" class="small"></span>
                        </div>
                    </div>
                    <div class="modal-footer">
                        <button type="button" class="btn btn-outline-secondary btn-sm" onclick="exportConfigurations(false)" title="Export without passwords">
                            <i class="fas fa-download"></i> Export
                        </button>
                        <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                        <button type="button" class="btn btn-primary" onclick="saveDbConfig()">
                            <i class="fas fa-plug"></i> Connect Now
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div class="toast-container position-fixed bottom-0 end-0 p-3" id="toastContainer" style="z-index: 1055;">
        </div>
        
        <!-- Implementation Guide Modal -->
        <div class="modal fade" id="guideModal" tabindex="-1">
            <div class="modal-dialog modal-lg modal-dialog-scrollable">
                <div class="modal-content">
                    <div class="modal-header bg-dark text-white">
                        <h5 class="modal-title">
                            <i class="fas fa-book me-2 text-primary"></i> Implementation Guide
                        </h5>
                        <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal"></button>
                    </div>
                    <div class="modal-body bg-light" id="guideModalBody">
                        @if (Model != null && !string.IsNullOrEmpty(Model.GeneratedHtml))
                        {
                            <div class="accordion shadow-sm" id="guideAccordionModal">
                                <!-- Step 1: Getting Started -->
                                <div class="accordion-item border-0 mb-2 rounded shadow-sm">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button bg-white text-dark fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#mStep1">
                                            <i class="fas fa-terminal me-2 text-primary"></i> 1. Prepare Component & Dependencies
                                        </button>
                                    </h2>
                                    <div id="mStep1" class="accordion-collapse collapse show" data-bs-parent="#guideAccordionModal">
                                        <div class="accordion-body bg-white pt-0">
                                            <label class="small text-muted mb-1">สร้าง Component ด้วยคำสั่ง:</label>
                                            <div class="bg-dark text-white p-2 rounded mb-3 d-flex justify-content-between align-items-center font-monospace" style="font-size: 0.85rem;">
                                                <span id="cliCommandModal">ng generate component <strong>@(Model.Selector)</strong> --standalone</span>
                                                <button type="button" class="btn btn-sm btn-outline-light py-0 px-2" onclick="copyText('cliCommandModal', true)"><i class="fa-regular fa-copy"></i></button>
                                            </div>
                                            
                                            <div class="alert alert-info border-0 small mb-0">
                                                <p class="mb-1 fw-bold text-dark"><i class="fas fa-info-circle me-1 text-info"></i> Excel & PDF Export:</p>
                                                <p class="mb-2 text-dark">หากคุณเปิดใช้งานฟีเจอร์ Export กรุณาติดตั้ง Library เพิ่มเติม:</p>
                                                <div class="bg-dark text-white p-2 rounded d-flex justify-content-between align-items-center font-monospace mb-0" style="font-size: 0.75rem;">
                                                    <span id="npmCommandModal">npm install xlsx@@^0.18.5 jspdf@@^2.5.2 jspdf-autotable@@^3.8.3</span>
                                                    <button type="button" class="btn btn-sm btn-outline-light py-0 px-1" onclick="copyText('npmCommandModal', true)"><i class="fa-regular fa-copy"></i></button>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Step 2: Routing Configuration -->
                                <div class="accordion-item border-0 mb-2 rounded shadow-sm">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed bg-white text-dark fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#mStep2">
                                            <i class="fas fa-route me-2 text-info"></i> 2. Register Routing
                                        </button>
                                    </h2>
                                    <div id="mStep2" class="accordion-collapse collapse" data-bs-parent="#guideAccordionModal">
                                        <div class="accordion-body bg-white pt-0">
                                            <div class="d-flex justify-content-between align-items-center mb-2 mt-2">
                                                <label class="fw-bold text-secondary small uppercase tracking-wider">Update app.routes.ts</label>
                                                <button type="button" class="btn btn-sm btn-outline-primary py-0" onclick="copyText('codeRoutingModal')">
                                                    <i class="fa-regular fa-copy me-1"></i> Copy Code
                                                </button>
                                            </div>
                                            <div class="rounded-3 overflow-hidden border">
                                                <pre class="m-0" style="background: #1e1e1e; font-size: 0.85rem;"><code id="codeRoutingModal" class="language-typescript">import { Routes } from '@@angular/router';
import { @(Model.EntityName)Component } from './@(Model.EntityName.ToLower())/@(Model.EntityName.ToLower()).component';

export const routes: Routes = [
  { 
    path: '@(Model.Selector)', 
    component: @(Model.EntityName)Component,
    title: '@(Model.EntityName) Management' 
  }
];</code></pre>
                                            </div>
                                        </div>
                                    </div>
                                </div>

                                <!-- Step 3: Global Setup -->
                                <div class="accordion-item border-0 mb-2 rounded shadow-sm">
                                    <h2 class="accordion-header">
                                        <button class="accordion-button collapsed bg-white text-dark fw-bold" type="button" data-bs-toggle="collapse" data-bs-target="#mStep3">
                                            <i class="fas fa-tools me-2 text-success"></i> 3. Global Project Setup
                                        </button>
                                    </h2>
                                    <div id="mStep3" class="accordion-collapse collapse" data-bs-parent="#guideAccordionModal">
                                        <div class="accordion-body bg-white pt-0 text-dark">
                                            <p class="small mb-2">ต้องตั้งค่าใน <code>app.config.ts</code> เพื่อรองรับ HTTP และ Module ต่างๆ:</p>
                                            <div class="rounded-3 overflow-hidden border mb-3">
                                                <pre class="m-0" style="background: #1e1e1e; font-size: 0.85rem;"><code class="language-typescript">import { provideHttpClient } from '@@angular/common/http';
import { provideAnimationsAsync } from '@@angular/platform-browser/animations/async';

export const appConfig: ApplicationConfig = {
  providers: [
    provideHttpClient(),
    provideAnimationsAsync(),
  ]
};</code></pre>
                                            </div>
                                            <div class="card border-info bg-light mb-0">
                                                <div class="card-body py-2">
                                                    <small class="text-info fw-bold"><i class="fas fa-exclamation-triangle me-1"></i> CORS Warning:</small>
                                                    <p class="small mb-0 text-dark">อย่าลืมอนุญาต URL <code>http://localhost:4200</code> ที่ API Backend</p>
                                                </div>
                                            </div>
                                            @if (Model.CssFramework == CSSFramework.AngularMaterial)
                                            {
                                                <div class="mt-2 p-2 border rounded bg-light">
                                                    <small class="fw-bold d-block mb-1 text-primary">Add to styles.css:</small>
                                                    <code class="small">@@import "@@angular/material/prebuilt-themes/indigo-pink.css";</code>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                </div>
                            </div>
                        }
                    </div>
                </div>
            </div>
        </div>
    </div>

    <footer class="text-center text-white">
        <div class="text-center bg-primary p-2">
            <p class="mb-0 font-monospace">
                <span class="text-dark">&lt;/&gt;</span> 
                Developed with <span class="text-dark fw-bold">Lutfee</span>
            </p>
        </div>
    </footer>

    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" asp-append-version="true"></script>
    
    <!-- jQuery (Required for Fomantic UI) -->
    <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script>

    <!-- Fomantic UI JS -->
    <script src="https://cdn.jsdelivr.net/npm/fomantic-ui@2.9.3/dist/semantic.min.js"></script>

    <!-- Custom JavaScript -->
    <script src="~/js/generator.js" asp-append-version="true"></script>
</body>
</html>