@using AngularGenerator.Core.Models
@model ComponentDefinition

@{
    ViewData["Title"] = "Angular CRUD Generator";
    Layout = null;

    // เช็คสถานะ Select All ของ CRUD
    bool isAllCrud = Model?.IsGet == true && Model?.IsGetById == true && Model?.IsPost == true && Model?.IsUpdate == true && Model?.IsDelete == true;
}

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Angular CRUD Generator</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">

    <style>
        body {
            background-color: #f4f6f9;
            font-family: 'Sarabun', sans-serif;
        }

        /* Header Style */
        .main-header {
            background-color: #007bff;
            color: white;
            padding: 15px 20px;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* DB Status Badge */
        .db-status {
            font-size: 0.9rem;
            padding: 5px 12px;
            border-radius: 20px;
            background: rgba(255,255,255,0.2);
            backdrop-filter: blur(5px);
        }

        .status-dot {
            height: 10px;
            width: 10px;
            background-color: #ccc;
            border-radius: 50%;
            display: inline-block;
            margin-right: 5px;
        }

        .status-online {
            background-color: #4ade80;
            box-shadow: 0 0 8px #4ade80;
        }

        .status-offline {
            background-color: #f87171;
        }

        /* Custom Cards */
        .card-settings .card-header {
            background-color: #66a3ff;
            color: white;
            font-weight: bold;
        }

        .card-result .card-header {
            background-color: #2e7d32;
            color: white;
            font-weight: bold;
            display: flex;
            justify-content: space-between;
            align-items: center;
        }

        /* Buttons */
        .btn-generate {
            background-color: #2e7d32;
            color: white;
            font-weight: bold;
            border: none;
        }

            .btn-generate:hover {
                background-color: #1b5e20;
                color: white;
            }

        /* Copy Button */
        .copy-btn {
            position: absolute;
            top: 10px;
            right: 15px;
            z-index: 10;
            opacity: 0.7;
            transition: 0.3s;
        }

            .copy-btn:hover {
                opacity: 1;
                transform: scale(1.1);
            }

        .tab-pane {
            position: relative;
        }
    </style>
</head>
<body>

    <div class="main-header shadow-sm">
        <h3 class="m-0"><i class="fa-brands fa-angular me-2"></i>Angular CRUD Generator</h3>
        <div class="db-status text-white d-flex align-items-center" id="dbStatusBadge">
            <span class="status-dot" id="dbStatusDot"></span>
            <span id="dbStatusText">Checking...</span>
            <button class="btn btn-sm btn-link text-white p-0 ms-2" onclick="checkDbStatus()" title="Refresh DB"><i class="fa-solid fa-rotate-right"></i></button>
        </div>
    </div>

    <div class="container-fluid mt-4 px-4">
        <form action="/Generator/Index" method="post" id="genForm">
            <div class="row">

                <!-- Config Form ด้านซ้าย (col-md-4) -->
                <div class="col-md-4">
                    <div class="card card-settings mb-4 shadow-sm">
                        <div class="card-header">ตั้งค่า</div>
                        <div class="card-body bg-light">

                            <div class="mb-3">
                                <label class="form-label fw-bold text-primary">Table Name</label>
                                <div class="input-group">
                                    <input type="text" id="tableNameInput" name="tableName" class="form-control"
                                           placeholder="e.g. Products" value="@ViewBag.LastTableName" required>
                                    <button class="btn btn-primary" type="button" id="btnLoad" onclick="loadColumns()">
                                        <i class="fa-solid fa-sync"></i> Load
                                    </button>
                                </div>
                                <small class="text-muted" id="loadStatus"></small>
                            </div>

                            <div class="card mb-3">
                                <div class="card-body py-2">
                                    <label class="fw-bold mb-2 d-block">
                                        FieldName
                                        <i class="fas fa-info-circle text-muted ms-1" title="Primary Key จะถูกใช้ใน GetById, Update, Delete"></i> 
                                    </label>

                                    <div class="form-check border-bottom pb-2 mb-2">
                                        <input class="form-check-input" type="checkbox" id="selectAllFields" checked onchange="toggleAllFields(this)">
                                        <label class="form-check-label fw-bold text-primary" for="selectAllFields">เลือกทั้งหมด</label>
                                    </div>

                                    <div id="fieldContainer" class="border rounded p-2 bg-white" style="max-height: 280px; overflow-y: auto;">
                                        @if (Model?.Fields != null && Model.Fields.Count > 0)
                                        {
                                            // ดึง List ของ Field ที่เคยเลือกไว้ (ถ้าเป็น null คือเพิ่ง load หรือเลือกทั้งหมด)
                                            var selected = ViewBag.SelectedFields as List<string>;

                                            <table class="table table-sm mb-0">
                                                <thead>
                                                    <tr>
                                                        <th style="width: 40px;">
                                                            <i class="fas fa-check text-success" title="Include"></i>
                                                        </th>
                                                        <th>Field Name</th>
                                                        <th>Type</th>
                                                    </tr>
                                                </thead>
                                                <tbody>
                                                    @foreach (var f in Model.Fields)
                                                    {
                                                        var isChecked = (selected == null || selected.Count == 0 || selected.Contains(f.FieldName)) ? "checked" : "";
                                                        // PK ต้อง checked เสมอและ disabled (ไม่ให้ uncheck)
                                                        var isDisabled = f.IsPrimaryKey ? "disabled" : "";
                                                        var pkChecked = f.IsPrimaryKey ? "checked" : isChecked;

                                                        <tr class="@(f.IsPrimaryKey ? "table-warning" : "")">
                                                            <td class="text-center">
                                                                <input class="form-check-input field-checkbox" type="checkbox" 
                                                                       name="selectedFields" value="@f.FieldName" 
                                                                       @pkChecked @isDisabled>
                                                                @* Hidden input สำหรับ PK เพื่อให้ส่งค่าไปได้แม้ disabled *@
                                                                @if (f.IsPrimaryKey)
                                                                {
                                                                    <input type="hidden" name="selectedFields" value="@f.FieldName">
                                                                }
                                                            </td>
                                                            <td>
                                                                <span class="fw-bold text-dark small">@f.FieldName</span>
                                                                @if (f.IsPrimaryKey)
                                                                {
                                                                    <i class="fas fa-key text-warning ms-1" title="Primary Key (Required)"></i>
                                                                    <span class="badge bg-warning text-dark ms-1" style="font-size: 0.65rem;">PK</span>
                                                                }
                                                            </td>
                                                            <td>
                                                                <span class="text-muted small">@f.TsType</span>
                                                            </td>
                                                        </tr>
                                                    }
                                                </tbody>
                                            </table>
                                        }
                                        else
                                        {
                                            <div class="h-100 d-flex align-items-center justify-content-center" style="min-height: 120px;">
                                                <small class="text-muted fst-italic" style="color:red">Table not found.</small>
                                            </div>
                                        }
                                    </div>
                                </div>
                            </div>

                            <div class="mb-3">
                                <label class="form-label fw-bold">Component Name</label>
                                <input type="text" name="componentName" class="form-control"
                                       placeholder="Auto-generated if empty (e.g. Products)"
                                       value="@(Model?.EntityName != null && Model.EntityName != ViewBag.LastTableName ? Model.EntityName : "")">
                            </div>

                            <!-- Report/CRUD Mode Selection -->
                            <div class="card mb-3">
                                @{
                                    var selectedMode = ViewBag.GenerationMode ?? "Report";
                                }
                                <div class="btn-group w-100" role="group">
                                    <input type="radio" class="btn-check" name="generationMode" id="modeReport" value="Report" @(selectedMode == "Report" ? "checked" : "") onchange="toggleCrudOptions()">
                                    <label class="btn btn-outline-primary btn-lg" for="modeReport">
                                        <i class="fas fa-file-alt"></i> Report
                                    </label>
                                    
                                    <input type="radio" class="btn-check" name="generationMode" id="modeCrud" value="CRUD" @(selectedMode == "CRUD" ? "checked" : "") onchange="toggleCrudOptions()">
                                    <label class="btn btn-outline-primary btn-lg" for="modeCrud">
                                        <i class="fas fa-database"></i> CRUD
                                    </label>
                                </div>
                                @* <small class="text-muted d-block mt-2">
                                    <strong>Report:</strong> แสดงข้อมูลอย่างเดียว (Read-only)
                                    <br> 
                                    <strong>CRUD:</strong> เลือก operations เอง
                                </small>  *@
                            </div>

                            <div class="card mb-3" id="crudOptionsCard">
                                <div class="card-body py-2">
                                    <label class="fw-bold mb-2 d-block">Choose CRUD</label>

                                    <div class="form-check border-bottom pb-2 mb-2">
                                        <input class="form-check-input" type="checkbox" id="selectAllCrud"
                                               onchange="toggleAllCrud(this)" @(isAllCrud ? "checked" : "")>
                                        <label class="form-check-label fw-bold text-primary " for="selectAllCrud">เลือกทั้งหมด</label>
                                    </div>

                                    <div class="row g-2">
                                        <div class="col-6">
                                            <div class="form-check">
                                                <input class="form-check-input" type="checkbox" id="IsGet" asp-for="IsGet" checked disabled>
                                                <input type="hidden" name="IsGet" value="true"> <!-- Always true -->
                                                <label class="form-check-label text-muted" for="IsGet">
                                                    <i class="fas fa-lock me-1"></i> Get (Read)
                                                    <span class="badge bg-primary ms-2" style="font-size: 0.7rem;">REQUIRED</span>
                                                </label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input crud-checkbox" type="checkbox" id="IsGetById" asp-for="IsGetById" onchange="updateGetByIdRequirement()">
                                                <label class="form-check-label" for="IsGetById">Get By ID</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input crud-checkbox" type="checkbox" id="IsPost" asp-for="IsPost" onchange="updateGetByIdRequirement()">
                                                <label class="form-check-label" for="IsPost">Post (Create)</label>
                                            </div>
                                        </div>
                                        <div class="col-6">
                                            <div class="form-check">
                                                <input class="form-check-input crud-checkbox" type="checkbox" id="IsUpdate" asp-for="IsUpdate" onchange="updateGetByIdRequirement()">
                                                <label class="form-check-label" for="IsUpdate">Update</label>
                                            </div>
                                            <div class="form-check">
                                                <input class="form-check-input crud-checkbox" type="checkbox" id="IsDelete" asp-for="IsDelete" onchange="updateGetByIdRequirement()">
                                                <label class="form-check-label" for="IsDelete">Delete</label>
                                            </div>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- API Base URL  -->
                            <div class="mb-3">
                                <label class="form-label fw-bold">
                                    API Base URL
                                    <i class="fas fa-info-circle text-muted ms-1" title="ใช้ใน Service สำหรับเรียก HTTP requests"></i>
                                </label>
                                <input type="text" id="apiBaseUrl" name="apiBaseUrl" class="form-control"
                                       placeholder="e.g. http://localhost:5000/api"
                                       value="@ViewBag.ApiBaseUrl">
                            </div>

                            <!-- NEW: UI Layout Selection -->
                            <div class="card mb-3">
                                <div class="card-header bg-info text-white py-2">
                                    <i class="fas fa-layout"></i> UI Layout
                                </div>
                                <div class="card-body py-2">
                                    @{
                                        var selectedLayout = ViewBag.LayoutType ?? Model?.LayoutType.ToString() ?? "TableView";
                                    }
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" name="layoutType" id="layoutTable" 
                                               value="TableView" @(selectedLayout == "TableView" ? "checked" : "")>
                                        <label class="form-check-label" for="layoutTable">
                                            <i class="fas fa-table"></i> Table View (รายการแบบตาราง)
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="layoutType" id="layoutCard" 
                                               value="CardView" @(selectedLayout == "CardView" ? "checked" : "")>
                                        <label class="form-check-label" for="layoutCard">
                                            <i class="fas fa-th-large"></i> Card View (รายการแบบการ์ด)
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <!-- CSS Framework Selection -->
                            <div class="card mb-3">
                                <div class="card-header bg-success text-white py-2">
                                    <i class="fas fa-palette"></i> CSS Framework
                                </div>
                                <div class="card-body py-2">
                                    @{
                                        var selectedFramework = ViewBag.CssFramework ?? Model?.CssFramework.ToString() ?? "Bootstrap";
                                    }
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" name="cssFramework" id="cssBasic" 
                                               value="BasicCSS" @(selectedFramework == "BasicCSS" ? "checked" : "")>
                                        <label class="form-check-label" for="cssBasic">
                                            <i class="fas fa-file-code"></i> Basic CSS
                                            <small class="text-muted d-block">✅ จะได้ไฟล์ .css เพิ่ม</small>
                                        </label>
                                    </div>
                                    <div class="form-check mb-2">
                                        <input class="form-check-input" type="radio" name="cssFramework" id="cssBootstrap" 
                                               value="Bootstrap" @(selectedFramework == "Bootstrap" ? "checked" : "")>
                                        <label class="form-check-label" for="cssBootstrap">
                                            <i class="fab fa-bootstrap"></i> Bootstrap 5
                                            <small class="text-muted d-block">ใช้ Bootstrap classes (Default)</small>
                                        </label>
                                    </div>
                                    <div class="form-check">
                                        <input class="form-check-input" type="radio" name="cssFramework" id="cssMaterial" 
                                               value="AngularMaterial" @(selectedFramework == "AngularMaterial" ? "checked" : "")>
                                        <label class="form-check-label" for="cssMaterial">
                                            <i class="fas fa-brush"></i> Angular Material
                                            <small class="text-muted d-block">ใช้ Material Design</small>
                                        </label>
                                    </div>
                                </div>
                            </div>

                            <button type="submit" class="btn btn-generate w-100 shadow-sm py-2">Generate Code</button>
                        </div>
                    </div>
                </div>

                <!-- Result ด้านขวา (col-md-8) -->
                <div class="col-md-8">
                    
                    <label class="fw-bold mb-1">Create Component</label>
                    <div class="bg-secondary text-white p-2 rounded mb-3 d-flex justify-content-between align-items-center font-monospace">
                        <span id="cliCommand">ng generate component <strong>@(Model?.Selector ?? "<component-name>")</strong> --standalone</span>
                        <button type="button" class="btn btn-sm btn-dark" onclick="copyText('cliCommand', true)"><i class="fa-regular fa-copy"></i></button>
                    </div>

                    @* API Endpoints Preview *@
                    @* @if (Model != null && !string.IsNullOrEmpty(Model.GeneratedService))
                    {
                        var apiBase = ViewBag.ApiBaseUrl ?? "/api";
                        var entityLower = Model.EntityName.ToLower();
                        
                        <div class="card mb-3 border-primary">
                            <div class="card-header bg-primary text-white">
                                <i class="fas fa-network-wired"></i> API Endpoints
                                <small class="ms-2">(copy สำหรับ Backend)</small>
                            </div>
                            <div class="card-body p-2">
                                <div class="table-responsive">
                                    <table class="table table-sm table-hover mb-0">
                                        <thead class="table-light">
                                            <tr>
                                                <th style="width: 80px;">Method</th>
                                                <th>Endpoint</th>
                                                <th style="width: 60px;"></th>
                                            </tr>
                                        </thead>
                                        <tbody class="font-monospace small">
